"use strict";
document.addEventListener("DOMContentLoaded", function() {
    var languageButtons = document.querySelectorAll(".change_language h3");
    var elementsToTranslate = document.querySelectorAll("[data-en], [data-fr], [data-ua]");
    // Function to change language
    var changeLanguage = function(language) {
        elementsToTranslate.forEach(function(element) {
            if (element.dataset[language]) element.textContent = element.dataset[language];
        });
    };
    // Add click event listeners to language buttons
    languageButtons.forEach(function(button) {
        button.addEventListener("click", function() {
            var language = button.classList.contains("change_language_en") ? "en" : button.classList.contains("change_language_fr") ? "fr" : button.classList.contains("change_language_ua") ? "ua" : null;
            if (language) changeLanguage(language);
        });
    });
});
///CAT
// Make the cat's pupils follow the cursor
document.addEventListener("mousemove", function(e) {
    var cat = document.querySelector(".cat");
    var pupils = document.querySelectorAll(".pupil");
    var mouseX = e.clientX;
    var mouseY = e.clientY;
    // Get the cat's position
    var catRect = cat.getBoundingClientRect();
    var catX = catRect.left + catRect.width / 2;
    var catY = catRect.top + catRect.height / 2;
    // Calculate the distance between the cursor and the cat
    var distance = Math.sqrt(Math.pow(mouseX - catX, 2) + Math.pow(mouseY - catY, 2));
    // If the cursor is within 100px of the cat, move the cat and eyes down
    if (distance < 100) cat.classList.add("move-down");
    else cat.classList.remove("move-down");
    // Calculate the angle between the cat and the cursor
    var angle = Math.atan2(mouseY - catY, mouseX - catX);
    // Calculate the distance the pupils should move
    var maxDistance = 5; // Maximum distance the pupils can move
    var pupilX = Math.cos(angle) * maxDistance;
    var pupilY = Math.sin(angle) * maxDistance;
    // Move the pupils
    pupils.forEach(function(pupil) {
        pupil.style.transform = "translate(calc(-50% + ".concat(pupilX, "px), calc(-50% + ").concat(pupilY, "px))");
    });
});
document.addEventListener("DOMContentLoaded", function() {
    var traits = document.querySelectorAll(".trait");
    traits.forEach(function(trait) {
        var percent = trait.getAttribute("data-percent");
        var circle = trait.querySelector(".circle");
        var angle = percent / 100 * 360;
        trait.style.background = "conic-gradient(#4caf50 ".concat(angle, "deg, #e0e0e0 ").concat(angle, "deg)");
        var radius = 100; // Radius of the circle
        var radians = (angle - 90) * (Math.PI / 180); // Convert degrees to radians
        var x = radius + radius * Math.cos(radians);
        var y = radius + radius * Math.sin(radians);
        circle.style.left = "".concat(x, "px");
        circle.style.top = "".concat(y, "px");
    });
});

